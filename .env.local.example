# Copy to .env.local and fill in. Get these from:
# Supabase Dashboard → Project Settings → API

# Project URL, e.g. https://abcdxyz.supabase.co
SUPABASE_URL=

# SERVICE ROLE key — server-side only, full access. NEVER expose to the browser
# or commit it. Used by lib/supabase.ts for moderated writes/reads.
SUPABASE_SERVICE_ROLE_KEY=

# (Optional) anon/public key — only needed if you later do reads from the browser.
# SUPABASE_ANON_KEY=

# Password for the /admin moderation desk. Pick a strong value in production.
ADMIN_PASSWORD=choose-a-strong-password
